#!/usr/bin/env bash

set -uo pipefail

CONFIG_DIR="$HOME/.frappe"
PROFILES_FILE="$CONFIG_DIR/profiles"
COOKIE_JAR="$CONFIG_DIR/cookies.txt"
SESSION_FILE="$CONFIG_DIR/session"
DEFAULT_PROFILE_FILE="$CONFIG_DIR/default_profile"

mkdir -p "$CONFIG_DIR"

# ─────────────────────────────────────────────
# SESSION PERSISTENCE (keeps FRAPPE_HOST etc. across invocations)
# ─────────────────────────────────────────────

FRAPPE_HOST=""
FRAPPE_USERNAME=""
FRAPPE_PASSWORD=""
FRAPPE_PROFILE_NAME=""

if [[ -f "$SESSION_FILE" ]]; then
  FRAPPE_HOST=$(sed -n '1p' "$SESSION_FILE")
  FRAPPE_USERNAME=$(sed -n '2p' "$SESSION_FILE")
  FRAPPE_PASSWORD=$(sed -n '3p' "$SESSION_FILE")
fi

save_session() {
  (umask 077; printf '%s\n%s\n%s\n' "$FRAPPE_HOST" "$FRAPPE_USERNAME" "$FRAPPE_PASSWORD" > "$SESSION_FILE")
}


# ─────────────────────────────────────────────
# COLORS
# ─────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

print_green() { echo -e "${GREEN}$*${NC}"; }
print_red()   { echo -e "${RED}$*${NC}"; }
print_yellow(){ echo -e "${YELLOW}$*${NC}"; }


# ─────────────────────────────────────────────
# UTILS
# ─────────────────────────────────────────────

fail() { echo "ERROR: $*" >&2; exit 1; }

log() { echo "[*] $*" >&2; }

require_login() {
  [[ -f "$COOKIE_JAR" ]] || fail "Not logged in. Run: frappe login"
  [[ -n "$FRAPPE_HOST" ]] || fail "Host not configured. Run: frappe login"
}

parse_datetime() {
  local raw="$1"
  echo "${raw%%.*}"
}

to_epoch() {
  date -d "$1" +%s 2>/dev/null || gdate -d "$1" +%s 2>/dev/null || echo 0
}

format_duration() {
  local secs="$1"
  printf '%02dh %02dm' $(( secs / 3600 )) $(( (secs % 3600) / 60 ))
}

# ─────────────────────────────────────────────
# PROFILE MANAGEMENT
# ─────────────────────────────────────────────

save_profile() {
  local name="$1" host="$2" user="$3" pass="$4"
  # Remove any existing entry with the same name before appending
  if [[ -f "$PROFILES_FILE" ]]; then
    awk -F'|' -v n="$name" '$1 != n' "$PROFILES_FILE" > "${PROFILES_FILE}.tmp"
    mv "${PROFILES_FILE}.tmp" "$PROFILES_FILE"
  fi
  printf '%s|%s|%s|%s\n' "$name" "$host" "$user" "$pass" >> "$PROFILES_FILE"
}

set_default_profile() {
  printf '%s\n' "$1" > "$DEFAULT_PROFILE_FILE"
}

load_default_profile() {
  [[ -f "$DEFAULT_PROFILE_FILE" ]] || return 1
  [[ -f "$PROFILES_FILE" ]]        || return 1

  local default_name line
  default_name=$(cat "$DEFAULT_PROFILE_FILE")
  line=$(awk -F'|' -v n="$default_name" '$1 == n { print; exit }' "$PROFILES_FILE")
  [[ -z "$line" ]] && return 1

  FRAPPE_PROFILE_NAME="${line%%|*}"
  local rest="${line#*|}"
  FRAPPE_HOST="${rest%%|*}"
  rest="${rest#*|}"
  FRAPPE_USERNAME="${rest%%|*}"
  FRAPPE_PASSWORD="${rest#*|}"
  return 0
}

# ─────────────────────────────────────────────
# LOGIN
# ─────────────────────────────────────────────

# Internal: re-authenticate using stored credentials (no prompts).
_do_login() {
  [[ -n "$FRAPPE_HOST" && -n "$FRAPPE_USERNAME" && -n "$FRAPPE_PASSWORD" ]] || return 1

  local response user
  response=$(curl -s -X POST \
    "$FRAPPE_HOST/login" \
    -c "$COOKIE_JAR" \
    --data-urlencode "usr=$FRAPPE_USERNAME" \
    --data-urlencode "pwd=$FRAPPE_PASSWORD" \
    --data-urlencode "cmd=login")

  user=$(echo "$response" | jq -r '.full_name // empty')
  [[ -n "$user" ]]
}

cmd_login() {
  local flag="${1:-}"
  rm -f "$COOKIE_JAR"

  case "$flag" in
    --guest)
      # Prompt for credentials but do not persist them
      read -rp "Host: " FRAPPE_HOST
      read -rp "User: " FRAPPE_USERNAME
      read -rsp "Password: " FRAPPE_PASSWORD
      echo
      ;;
    --new)
      # Prompt for brand-new credentials, save as new default profile
      read -rp "Host: " FRAPPE_HOST
      read -rp "User: " FRAPPE_USERNAME
      read -rsp "Password: " FRAPPE_PASSWORD
      echo
      read -rp "Profile name [default]: " FRAPPE_PROFILE_NAME
      FRAPPE_PROFILE_NAME="${FRAPPE_PROFILE_NAME:-default}"
      save_profile "$FRAPPE_PROFILE_NAME" "$FRAPPE_HOST" "$FRAPPE_USERNAME" "$FRAPPE_PASSWORD"
      set_default_profile "$FRAPPE_PROFILE_NAME"
      log "Saved as profile '$FRAPPE_PROFILE_NAME'"
      ;;
    *)
      if load_default_profile; then
        log "Using profile '$FRAPPE_PROFILE_NAME' ($FRAPPE_HOST)"
      else
        # First-time setup: prompt and auto-save as default profile
        read -rp "Host: " FRAPPE_HOST
        read -rp "User: " FRAPPE_USERNAME
        read -rsp "Password: " FRAPPE_PASSWORD
        echo
        read -rp "Profile name [default]: " FRAPPE_PROFILE_NAME
        FRAPPE_PROFILE_NAME="${FRAPPE_PROFILE_NAME:-default}"
        save_profile "$FRAPPE_PROFILE_NAME" "$FRAPPE_HOST" "$FRAPPE_USERNAME" "$FRAPPE_PASSWORD"
        set_default_profile "$FRAPPE_PROFILE_NAME"
        log "Saved as profile '$FRAPPE_PROFILE_NAME'"
      fi
      ;;
  esac

  log "Logging in..."

  local response
  response=$(curl -s -X POST \
    "$FRAPPE_HOST/login" \
    -c "$COOKIE_JAR" \
    --data-urlencode "usr=$FRAPPE_USERNAME" \
    --data-urlencode "pwd=$FRAPPE_PASSWORD" \
    --data-urlencode "cmd=login")

  local user
  user=$(echo "$response" | jq -r '.full_name // empty')

  [[ -z "$user" ]] && fail "Login failed"

  save_session
  log "Logged in as $user"
}

# ─────────────────────────────────────────────
# LOGOUT
# ─────────────────────────────────────────────

cmd_logout() {
  rm -f "$COOKIE_JAR" "$SESSION_FILE"
  echo "Logged out."
}

# ─────────────────────────────────────────────
# REQUEST
# ─────────────────────────────────────────────

# Returns 0 (true) when the response indicates an expired/invalid session.
_is_auth_error() {
  local response="$1"
  echo "$response" | jq -e \
    '(.exc_type? == "AuthenticationError") or
     (.message? // "" | ascii_downcase | test("not permitted|session.*expired"))' \
    > /dev/null 2>&1
}

frappe_request() {
  require_login

  local endpoint="$1"
  shift

  local attempt response
  for (( attempt = 1; attempt <= 3; attempt++ )); do
    response=$(curl -s \
      -b "$COOKIE_JAR" \
      -c "$COOKIE_JAR" \
      "$endpoint" "$@")

    if ! _is_auth_error "$response"; then
      echo "$response"
      return 0
    fi

    if (( attempt < 3 )); then
      log "Session expired, re-logging in (attempt $attempt/3)..."
      _do_login || log "Re-login attempt $attempt failed, retrying..."
    fi
  done

  fail "Session expired after 3 attempts. Please run: frappe login"
}

get_current_state() {
  local res
  res=$(frappe_request \
    "$FRAPPE_HOST/api/resource/Employee%20Checkin" \
    -G \
    --data-urlencode 'fields=["log_type","creation"]' \
    --data-urlencode "order_by=creation desc" \
    --data-urlencode "limit_page_length=1"
  )

  echo "$res" | jq -r '.data[0].log_type // empty'
}

# ─────────────────────────────────────────────
# CHECKINS
# ─────────────────────────────────────────────

cmd_get_checking_records() {
  require_login

  local limit="${1:-8}"

  local res
  res=$(frappe_request \
    "$FRAPPE_HOST/api/resource/Employee%20Checkin" \
    -G \
    --data-urlencode 'fields=["log_type","creation"]' \
    --data-urlencode "order_by=creation desc" \
    --data-urlencode "limit_page_length=$limit"
  )

  echo "$res" | jq -r '.data[] | "\(.log_type) \(.creation)"'
}

# ─────────────────────────────────────────────
# DO CHECKIN / CHECKOUT
# ─────────────────────────────────────────────

do_log() {
  local type="$1"

  require_login

  log "Sending $type..."

  # Try the HRMS app path (ERPNext v14+); fall back to legacy erpnext.hr path
  local endpoint="$FRAPPE_HOST/api/method/hrms.hr.doctype.employee_checkin.employee_checkin.add_log_based_on_employee_field"
  local res
  res=$(frappe_request "$endpoint" -X POST --data-urlencode "log_type=$type")

  if echo "$res" | jq -e '.exc_type? == "ValidationError"' > /dev/null 2>&1 && \
     echo "$res" | grep -q "No module named 'hrms'"; then
    log "HRMS module not found, trying legacy ERPNext HR path..."
    endpoint="$FRAPPE_HOST/api/method/erpnext.hr.doctype.employee_checkin.employee_checkin.add_log_based_on_employee_field"
    res=$(frappe_request "$endpoint" -X POST --data-urlencode "log_type=$type")
  fi

  echo "$res" | jq .
}

get_today_duration() {
  local today
  today=$(date +%Y-%m-%d)

  local res
  res=$(frappe_request \
    "$FRAPPE_HOST/api/resource/Employee%20Checkin" \
    -G \
    --data-urlencode 'fields=["log_type","creation"]' \
    --data-urlencode "order_by=creation asc" \
    --data-urlencode "limit_page_length=50"
  )

  local entries
  entries=$(echo "$res" | jq -r --arg today "$today" \
    '.data[] | select(.creation | startswith($today)) | "\(.log_type)|\(.creation)"')

  local last_in="" total=0 type dt diff

  while IFS="|" read -r type dt; do
    dt="${dt%%.*}"
    if [[ "$type" == "IN" ]]; then
      last_in="$dt"
    elif [[ "$type" == "OUT" && -n "$last_in" ]]; then
      diff=$(( $(to_epoch "$dt") - $(to_epoch "$last_in") ))
      total=$(( total + diff ))
      last_in=""
    fi
  done <<< "$entries"

  echo "$total"
}

cmd_get_checking_state() {
  require_login

  local res
  res=$(frappe_request \
    "$FRAPPE_HOST/api/resource/Employee%20Checkin" \
    -G \
    --data-urlencode 'fields=["log_type","creation"]' \
    --data-urlencode "order_by=creation desc" \
    --data-urlencode "limit_page_length=1"
  )

  local state ts
  state=$(echo "$res" | jq -r '.data[0].log_type // empty')
  ts=$(echo "$res" | jq -r '.data[0].creation // empty')
  ts="${ts%%.*}"

  case "$state" in
    IN)
      local elapsed
      elapsed=$(( $(date +%s) - $(to_epoch "$ts") ))
      print_green "IN  — checked in for $(format_duration $elapsed)"
      ;;
    OUT)
      local today_secs
      today_secs=$(get_today_duration)
      print_red "OUT — worked $(format_duration $today_secs) today"
      ;;
    *)
      print_yellow "UNKNOWN (no records found)"
      ;;
  esac
}

cmd_checkin() {
  require_login

  local state
  state=$(get_current_state)

  if [[ "$state" == "IN" ]]; then
    print_yellow "⚠ Already checked in"
    return 0
  fi

  do_log "IN" && print_green "✓ Check-in recorded"
}

cmd_checkout() {
  require_login

  local state
  state=$(get_current_state)

  if [[ "$state" == "OUT" ]]; then
    print_yellow "⚠ Already checked out"
    return 0
  fi

  if [[ -z "$state" ]]; then
    print_red "✗ Cannot checkout: no prior check-in"
    return 1
  fi

  do_log "OUT" && print_green "✓ Check-out recorded"
}

# ─────────────────────────────────────────────
# HOURS
# ─────────────────────────────────────────────

cmd_get_hours() {
  require_login

  local limit="${1:-8}"
  local res
  res=$(frappe_request \
    "$FRAPPE_HOST/api/resource/Employee%20Checkin" \
    -G \
    --data-urlencode 'fields=["log_type","creation"]' \
    --data-urlencode "order_by=creation desc" \
    --data-urlencode "limit_page_length=$limit" 
  )

  local entries
  entries=$(echo "$res" | jq -r '.data[] | "\(.log_type)|\(.creation)"')
  
  local last_out="" last_out_date="" pairs="" dt date diff use_date

  while IFS="|" read -r type dt; do
    dt="${dt%%.*}"
    date="${dt%% *}"

    if [[ "$type" == "OUT" ]]; then
      last_out="$dt"
      last_out_date="$date"
    elif [[ "$type" == "IN" && -n "$last_out" ]]; then
      diff=$(( - $(to_epoch "$dt") + $(to_epoch "$last_out") ))
      use_date="${last_out_date:-$date}"
      pairs+="${use_date} ${diff}"$'\n'
      last_out=""
      last_out_date=""
    fi
  done <<< "$entries"

  if [[ -z "$pairs" ]]; then
    print_yellow "No check-in/out pairs found."
    return 0
  fi

  # Sort pairs by date, then aggregate seconds per date and print totals
  printf '%s' "$pairs" | awk '
    { sum[$1] += $2; grand += $2; if (!seen[$1]++) dates[++n] = $1 }
    END {
      for (i = 1; i <= n; i++) {
        d = dates[i]
        printf "%s  →  %02dh %02dm\n", d, sum[d]/3600, (sum[d]%3600)/60
      }
      print "──────────────────────────"
      printf "Total:  %02dh %02dm\n", grand/3600, (grand%3600)/60
    }
  '
}

# ─────────────────────────────────────────────
# CLI
# ─────────────────────────────────────────────

case "${1:-}" in
  login) shift; cmd_login "$@" ;;
  logout) cmd_logout ;;

  get-checking-records) shift; cmd_get_checking_records "$@" ;;
  get-checking-state) cmd_get_checking_state ;;
  get-hours) shift; cmd_get_hours "$@" ;;

  do-checkin) cmd_checkin ;;
  do-checkout) cmd_checkout ;;

  *)
    cat <<EOF
Commands:
  frappe login           # use saved default profile (or first-time setup)
  frappe login --new     # enter new credentials and save as new default
  frappe login --guest   # one-off login, nothing saved
  frappe logout

  frappe get-checking-records [limit]
  frappe get-checking-state
  frappe get-hours [limit]

  frappe do-checkin
  frappe do-checkout
EOF
    ;;
esac
